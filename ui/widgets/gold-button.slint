import { Theme } from "../theme.slint";

// Primary-action button in the Aicam gold accent.
export component GoldButton inherits Rectangle {
    in property <string> text;
    callback clicked;

    height: 32px;
    border-radius: 6px;
    background: touch.pressed ? Theme.gold-500
              : touch.has-hover ? Theme.gold-300
              : Theme.gold;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        Text {
            text: root.text;
            color: #202020;
            font-weight: 600;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
