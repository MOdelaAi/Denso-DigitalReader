import { Theme } from "../theme.slint";

export component TextButton inherits Rectangle {
    in property <string> text;
    callback clicked;
    height: 32px;
    border-radius: 6px;
    horizontal-stretch: 0;
    background: touch.has-hover ? Theme.panel-3 : transparent;
    animate background { duration: 120ms; easing: ease-out; }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        Text {
            text: root.text;
            color: touch.has-hover ? Theme.txt : Theme.txt-faint;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
