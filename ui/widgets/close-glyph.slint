import { Theme } from "../theme.slint";

export component CloseGlyph inherits Rectangle {
    callback clicked;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: touch.has-hover ? Theme.panel-3 : transparent;
    animate background { duration: 120ms; easing: ease-out; }

    Text {
        text: "✕";
        font-size: 14px;
        color: touch.has-hover ? Theme.txt : Theme.txt-faint;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
