import { Theme } from "../theme.slint";

// A small "?" glyph that reveals an explanation box on hover. Uses a
// PopupWindow so the box renders above the card/ScrollView and is never
// clipped by them.
export component HelpHint inherits Rectangle {
    in property <string> text;
    width: 16px;
    height: 16px;

    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: ta.has-hover ? Theme.gold : Theme.panel-2;
        Text {
            text: "?";
            color: ta.has-hover ? Theme.panel : Theme.txt-faint;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    popup := PopupWindow {
        x: 22px;
        y: -4px;
        width: 240px;
        close-policy: PopupClosePolicy.no-auto-close;
        Rectangle {
            background: Theme.panel-3;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.panel-2;
            drop-shadow-blur: 14px;
            drop-shadow-color: #000000aa;
            drop-shadow-offset-y: 4px;
            HorizontalLayout {
                padding: 10px;
                Text {
                    text: root.text;
                    color: Theme.txt-dim;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
    }

    ta := TouchArea {
        changed has-hover => {
            if (self.has-hover) {
                popup.show();
            } else {
                popup.close();
            }
        }
    }
}
