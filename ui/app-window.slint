import { Button, HorizontalBox, VerticalBox } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { SettingsModal } from "settings-modal.slint";
import { NetStatus, NetConfigUi, WifiRow } from "settings/network.slint";

// Re-export so Rust can reach the Theme global via app.global::<Theme>().
export { Theme }

export component AppWindow inherits Window {
    title: "Denso Digital Reader";
    icon: @image-url("../assets/icon.png");
    preferred-width: 1600px;
    preferred-height: 900px;

    property <bool> settings-open: false;
    in-out property <int> resolution-index: 2;
    in-out property <bool> fullscreen: false;
    in property <string> app-version;
    in property <string> hw-os;
    in property <string> hw-device;
    in property <string> hw-ram;
    in property <string> hw-storage;
    in property <NetStatus> eth;
    in property <NetStatus> wifi;
    in property <bool> net-loading;
    in property <NetConfigUi> eth-config;
    in property <NetConfigUi> wifi-config;
    in property <string> eth-config-status;
    in property <string> wifi-config-status;
    in property <[WifiRow]> wifi-networks;
    in property <bool> wifi-scanning;
    in property <string> wifi-connect-status;
    callback refresh-network();
    callback apply-net-config(string, NetConfigUi);
    callback scan-wifi();
    callback connect-wifi(string, string);
    callback apply-resolution(int);
    callback theme-changed(bool);
    callback toggle-fullscreen(bool);
    callback reset-defaults();

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Top button bar
        Rectangle {
            height: 40px;
            background: Theme.panel-2;

            HorizontalBox {
                padding: 4px;
                alignment: end;

                Button {
                    text: "Settings";
                    clicked => { root.settings-open = true; }
                }
            }
        }

        // Main content area
        Rectangle {
            background: Theme.panel;
        }
    }

    // Settings modal overlay
    if root.settings-open : SettingsModal {
        resolution-index <=> root.resolution-index;
        fullscreen <=> root.fullscreen;
        app-version: root.app-version;
        hw-os: root.hw-os;
        hw-device: root.hw-device;
        hw-ram: root.hw-ram;
        hw-storage: root.hw-storage;
        eth: root.eth;
        wifi: root.wifi;
        net-loading: root.net-loading;
        eth-config: root.eth-config;
        wifi-config: root.wifi-config;
        eth-config-status: root.eth-config-status;
        wifi-config-status: root.wifi-config-status;
        wifi-networks: root.wifi-networks;
        wifi-scanning: root.wifi-scanning;
        wifi-connect-status: root.wifi-connect-status;
        refresh-network => { root.refresh-network(); }
        apply-net-config(i, c) => { root.apply-net-config(i, c); }
        scan-wifi => { root.scan-wifi(); }
        connect-wifi(s, p) => { root.connect-wifi(s, p); }
        apply-resolution(i) => { root.apply-resolution(i); }
        theme-changed(d) => { root.theme-changed(d); }
        toggle-fullscreen(f) => { root.toggle-fullscreen(f); }
        reset-defaults => { root.reset-defaults(); }
        close => { root.settings-open = false; }
    }
}
