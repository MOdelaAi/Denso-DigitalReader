import { LineEdit, ComboBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Eyebrow } from "../widgets/eyebrow.slint";
import { SpecRow } from "../widgets/spec-row.slint";
import { TextButton } from "../widgets/text-button.slint";
import { HelpHint } from "../widgets/help-hint.slint";

export struct NetStatus {
    connected: bool,
    ip: string,
    gateway: string,
    ssid: string,
    signal: string,
}

// Editable network configuration for one interface (strings; Rust parses).
export struct NetConfigUi {
    mode: string,    // "dhcp" | "static"
    ip: string,
    prefix: string,
    gateway: string,
    dns1: string,
    dns2: string,
}

// A scanned Wi-Fi network.
export struct WifiRow {
    ssid: string,
    signal: string,
    secured: bool,
    connected: bool,
}

// One row in the scan list. Tapping expands it; a secured network reveals a
// (masked) password field, an open one just a Connect button. The password
// lives in a persistent property so Connect reads it regardless of layout.
component WifiRowItem inherits VerticalLayout {
    in property <string> ssid;
    in property <string> signal;
    in property <bool> secured;
    in property <bool> connected;
    callback connect(string); // password ("" for open networks)
    property <bool> expanded: false;
    in-out property <string> password;
    spacing: 4px;

    Rectangle {
        height: 30px;
        border-radius: 4px;
        background: touch.has-hover ? Theme.panel-2 : transparent;
        HorizontalLayout {
            padding-left: 6px;
            padding-right: 6px;
            spacing: 8px;
            Text {
                text: root.ssid;
                color: root.connected ? Theme.status-ok : Theme.txt;
                font-weight: root.connected ? 600 : 400;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            if root.connected : Text {
                text: "Connected";
                color: Theme.status-ok;
                font-size: 11px;
                vertical-alignment: center;
            }
            Text {
                text: root.secured ? "🔒" : "";
                color: Theme.txt-faint;
                vertical-alignment: center;
            }
            Text {
                text: root.signal;
                color: Theme.txt-faint;
                vertical-alignment: center;
            }
        }
        touch := TouchArea {
            clicked => { root.expanded = !root.expanded; }
        }
    }

    if root.expanded : HorizontalLayout {
        spacing: 8px;
        padding-left: 6px;
        if root.secured : LineEdit {
            placeholder-text: "Password";
            input-type: InputType.password;
            text <=> root.password;
            horizontal-stretch: 1;
        }
        TextButton {
            text: "Connect";
            clicked => { root.connect(root.secured ? root.password : ""); }
        }
    }
}

// A labelled text input row. `text` is two-way so the card can read it back.
// A non-empty `hint` adds a hover "?" explaining the field.
component FieldRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> hint;
    in-out property <string> text;
    spacing: 8px;
    Text {
        text: root.label;
        color: Theme.txt-dim;
        width: 72px;
        vertical-alignment: center;
    }
    LineEdit {
        text <=> root.text;
        horizontal-stretch: 1;
    }
    if root.hint != "" : HelpHint {
        text: root.hint;
        y: parent.height / 2 - self.height / 2;
    }
}

// One interface: live status on top, editable IP/DNS config below. The static
// fields are an `if` (so DHCP truly collapses them) but their values live in
// persistent card properties, so Apply can read them whether shown or not.
component NetCard inherits Rectangle {
    in property <string> title;
    in property <string> iface;
    in property <bool> is-wifi;
    in property <NetStatus> status;
    in property <NetConfigUi> config;
    in property <string> config-status;
    callback apply(string, NetConfigUi);

    // Wi-Fi scan/connect (only wired for the Wi-Fi card).
    in property <[WifiRow]> networks;
    in property <bool> scanning;
    in property <string> connect-status;
    callback scan();
    callback connect(string, string); // ssid, password

    // Persistent edit state (survives the static fields being hidden).
    in-out property <string> ip;
    in-out property <string> prefix;
    in-out property <string> gateway;
    in-out property <string> dns1;
    in-out property <string> dns2;
    property <bool> is-static: mode-combo.current-index == 1;

    background: Theme.panel-3;
    border-radius: 8px;

    init => {
        mode-combo.current-index = root.config.mode == "static" ? 1 : 0;
        root.ip = root.config.ip;
        root.prefix = root.config.prefix;
        root.gateway = root.config.gateway;
        root.dns1 = root.config.dns1;
        root.dns2 = root.config.dns2;
    }

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        // ── Status ──
        HorizontalLayout {
            Text {
                text: root.title;
                color: Theme.txt;
                font-weight: 600;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
            Text {
                text: root.status.connected ? "Connected" : "Disconnected";
                color: root.status.connected ? Theme.status-ok : Theme.status-neutral;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
        if root.is-wifi : SpecRow { label: "SSID"; value: root.status.ssid == "" ? "—" : root.status.ssid; }
        if root.is-wifi : SpecRow { label: "Signal"; value: root.status.signal == "" ? "—" : root.status.signal; }
        SpecRow { label: "IP"; value: root.status.ip == "" ? "—" : root.status.ip; }
        SpecRow { label: "Gateway"; value: root.status.gateway == "" ? "—" : root.status.gateway; }

        // ── Wi-Fi scan / connect ──
        if root.is-wifi : Rectangle {
            min-height: 1px;
            max-height: 1px;
            background: Theme.panel-2;
        }
        if root.is-wifi : HorizontalLayout {
            Text {
                text: "Available networks";
                color: Theme.txt-dim;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            TextButton {
                text: root.scanning ? "Scanning…" : "Scan";
                clicked => { root.scan(); }
            }
        }
        if root.is-wifi : VerticalLayout {
            spacing: 2px;
            for net in root.networks : WifiRowItem {
                ssid: net.ssid;
                signal: net.signal;
                secured: net.secured;
                connected: net.connected;
                connect(pw) => { root.connect(net.ssid, pw); }
            }
        }
        if root.is-wifi && root.connect-status != "" : Text {
            text: root.connect-status;
            color: Theme.txt-dim;
            font-size: 12px;
        }

        // ── Divider ──
        Rectangle {
            min-height: 1px;
            max-height: 1px;
            background: Theme.panel-2;
        }

        // ── Config ──
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Mode";
                color: Theme.txt-dim;
                width: 72px;
                vertical-alignment: center;
            }
            mode-combo := ComboBox {
                model: ["DHCP", "Static"];
                horizontal-stretch: 1;
            }
            HelpHint {
                text: "DHCP gets these settings automatically from the network. Static lets you set them by hand.";
                y: parent.height / 2 - self.height / 2;
            }
        }

        if root.is-static : VerticalLayout {
            spacing: 6px;
            FieldRow {
                label: "IP";
                text <=> root.ip;
                hint: "This device's address on the network, e.g. 192.168.1.50. Must be unique.";
            }
            FieldRow {
                label: "Prefix";
                text <=> root.prefix;
                hint: "Subnet size as a CIDR prefix length (0–32). 24 means 255.255.255.0.";
            }
            FieldRow {
                label: "Gateway";
                text <=> root.gateway;
                hint: "The router address that traffic to other networks is sent through.";
            }
            FieldRow {
                label: "DNS 1";
                text <=> root.dns1;
                hint: "Primary DNS server, which resolves names to addresses, e.g. 8.8.8.8.";
            }
            FieldRow {
                label: "DNS 2";
                text <=> root.dns2;
                hint: "Backup DNS server, used when the primary is unreachable. Optional.";
            }
        }

        HorizontalLayout {
            spacing: 12px;
            Text {
                text: root.config-status;
                color: root.config-status == "Applied" ? Theme.status-ok : Theme.status-bad;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            TextButton {
                text: "Apply";
                clicked => {
                    root.apply(root.iface, {
                        mode: root.is-static ? "static" : "dhcp",
                        ip: root.ip,
                        prefix: root.prefix,
                        gateway: root.gateway,
                        dns1: root.dns1,
                        dns2: root.dns2,
                    });
                }
            }
        }
    }
}

export component Network inherits VerticalLayout {
    in property <NetStatus> eth;
    in property <NetStatus> wifi;
    in property <bool> loading;
    in property <NetConfigUi> eth-config;
    in property <NetConfigUi> wifi-config;
    in property <string> eth-config-status;
    in property <string> wifi-config-status;
    in property <[WifiRow]> wifi-networks;
    in property <bool> wifi-scanning;
    in property <string> wifi-connect-status;
    callback refresh();
    callback apply-config(string, NetConfigUi);
    callback scan-wifi();
    callback connect-wifi(string, string);
    spacing: 12px;

    HorizontalLayout {
        Eyebrow { text: "NETWORK"; vertical-alignment: center; horizontal-stretch: 1; }
        TextButton { text: root.loading ? "Loading…" : "Refresh"; clicked => { root.refresh(); } }
    }

    NetCard {
        title: "Ethernet";
        iface: "ethernet";
        is-wifi: false;
        status: root.eth;
        config: root.eth-config;
        config-status: root.eth-config-status;
        opacity: root.loading ? 0.5 : 1.0;
        apply(i, c) => { root.apply-config(i, c); }
    }
    NetCard {
        title: "Wi-Fi";
        iface: "wifi";
        is-wifi: true;
        status: root.wifi;
        config: root.wifi-config;
        config-status: root.wifi-config-status;
        networks: root.wifi-networks;
        scanning: root.wifi-scanning;
        connect-status: root.wifi-connect-status;
        opacity: root.loading ? 0.5 : 1.0;
        apply(i, c) => { root.apply-config(i, c); }
        scan => { root.scan-wifi(); }
        connect(s, p) => { root.connect-wifi(s, p); }
    }
}
