import { LineEdit, ComboBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Eyebrow } from "../widgets/eyebrow.slint";
import { SpecRow } from "../widgets/spec-row.slint";
import { TextButton } from "../widgets/text-button.slint";

export struct NetStatus {
    connected: bool,
    ip: string,
    gateway: string,
    ssid: string,
    signal: string,
}

// Editable network configuration for one interface (strings; Rust parses).
export struct NetConfigUi {
    mode: string,    // "dhcp" | "static"
    ip: string,
    prefix: string,
    gateway: string,
    dns1: string,
    dns2: string,
}

// Connection card for one interface.
component NetCard inherits Rectangle {
    in property <string> title;
    in property <NetStatus> status;
    in property <bool> is-wifi;
    background: Theme.panel-3;
    border-radius: 8px;
    VerticalLayout {
        padding: 12px;
        spacing: 6px;
        HorizontalLayout {
            Text {
                text: root.title;
                color: Theme.txt;
                font-weight: 600;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
            Text {
                text: root.status.connected ? "Connected" : "Disconnected";
                color: root.status.connected ? Theme.status-ok : Theme.status-neutral;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
        if root.is-wifi : SpecRow { label: "SSID"; value: root.status.ssid == "" ? "—" : root.status.ssid; }
        if root.is-wifi : SpecRow { label: "Signal"; value: root.status.signal == "" ? "—" : root.status.signal; }
        SpecRow { label: "IP"; value: root.status.ip == "" ? "—" : root.status.ip; }
        SpecRow { label: "Gateway"; value: root.status.gateway == "" ? "—" : root.status.gateway; }
    }
}

// A labelled text input row. `text` is two-way so the editor can read it back.
component FieldRow inherits HorizontalLayout {
    in property <string> label;
    in-out property <string> text;
    spacing: 8px;
    Text {
        text: root.label;
        color: Theme.txt-dim;
        width: 72px;
        vertical-alignment: center;
    }
    LineEdit {
        text <=> root.text;
        horizontal-stretch: 1;
    }
}

// IP/DNS editor for one interface. Seeds from `config` on creation; emits the
// gathered values via `apply` on the button press.
component NetConfigEditor inherits Rectangle {
    in property <string> title;
    in property <string> iface;
    in property <NetConfigUi> config;
    in property <string> status;
    callback apply(string, NetConfigUi);

    property <bool> is-static: mode-combo.current-index == 1;
    background: Theme.panel-3;
    border-radius: 8px;

    init => {
        mode-combo.current-index = root.config.mode == "static" ? 1 : 0;
        ip-row.text = root.config.ip;
        prefix-row.text = root.config.prefix;
        gw-row.text = root.config.gateway;
        dns1-row.text = root.config.dns1;
        dns2-row.text = root.config.dns2;
    }

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        Text {
            text: root.title;
            color: Theme.txt;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Mode";
                color: Theme.txt-dim;
                width: 72px;
                vertical-alignment: center;
            }
            mode-combo := ComboBox {
                model: ["DHCP", "Static"];
                horizontal-stretch: 1;
            }
        }

        // Always instantiated so ids stay valid; collapsed when on DHCP.
        static-fields := VerticalLayout {
            visible: root.is-static;
            spacing: 8px;
            ip-row := FieldRow { label: "IP"; }
            prefix-row := FieldRow { label: "Prefix"; }
            gw-row := FieldRow { label: "Gateway"; }
            dns1-row := FieldRow { label: "DNS 1"; }
            dns2-row := FieldRow { label: "DNS 2"; }
        }

        HorizontalLayout {
            spacing: 12px;
            TextButton {
                text: "Apply";
                clicked => {
                    root.apply(root.iface, {
                        mode: root.is-static ? "static" : "dhcp",
                        ip: ip-row.text,
                        prefix: prefix-row.text,
                        gateway: gw-row.text,
                        dns1: dns1-row.text,
                        dns2: dns2-row.text,
                    });
                }
            }
            Text {
                text: root.status;
                color: root.status == "Applied" ? Theme.status-ok : Theme.status-bad;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }
    }
}

export component Network inherits VerticalLayout {
    in property <NetStatus> eth;
    in property <NetStatus> wifi;
    in property <bool> loading;
    in property <NetConfigUi> eth-config;
    in property <NetConfigUi> wifi-config;
    in property <string> eth-config-status;
    in property <string> wifi-config-status;
    callback refresh();
    callback apply-config(string, NetConfigUi);
    spacing: 12px;

    HorizontalLayout {
        Eyebrow { text: "NETWORK"; vertical-alignment: center; horizontal-stretch: 1; }
        TextButton { text: root.loading ? "Loading…" : "Refresh"; clicked => { root.refresh(); } }
    }
    NetCard { title: "Ethernet"; status: root.eth; is-wifi: false; opacity: root.loading ? 0.5 : 1.0; }
    NetCard { title: "Wi-Fi"; status: root.wifi; is-wifi: true; opacity: root.loading ? 0.5 : 1.0; }

    NetConfigEditor {
        title: "Ethernet configuration";
        iface: "ethernet";
        config: root.eth-config;
        status: root.eth-config-status;
        apply(i, c) => { root.apply-config(i, c); }
    }
    NetConfigEditor {
        title: "Wi-Fi configuration";
        iface: "wifi";
        config: root.wifi-config;
        status: root.wifi-config-status;
        apply(i, c) => { root.apply-config(i, c); }
    }
}
