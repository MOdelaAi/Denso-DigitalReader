import { Button } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { GoldButton } from "widgets/gold-button.slint";
import { CloseGlyph } from "widgets/close-glyph.slint";
import { TextButton } from "widgets/text-button.slint";
import { NavItem } from "widgets/nav-item.slint";
import { Appearance } from "settings/appearance.slint";
import { Display } from "settings/display.slint";
import { System } from "settings/system.slint";
import { About } from "settings/about.slint";

// Full-window modal: scrim + centered, elevated instrument-panel dialog
// that hugs its content. Fades in on open.
export component SettingsModal inherits Rectangle {
    in-out property <int> resolution-index;
    in-out property <bool> fullscreen;
    in property <string> app-version;
    in property <string> hw-os;
    in property <string> hw-device;
    in property <string> hw-ram;
    in property <string> hw-storage;
    property <int> active-tab: 0;
    callback apply-resolution(int);
    callback theme-changed(bool);
    callback toggle-fullscreen(bool);
    callback reset-defaults();
    callback close();

    // Drives the fade-in (false -> true on creation).
    property <bool> shown: false;
    init => { shown = true; }

    width: 100%;
    height: 100%;
    background: Theme.overlay;
    opacity: shown ? 1.0 : 0.0;
    animate opacity { duration: 160ms; easing: ease-out; }

    // Center the dialog without stretching it (alignment: center makes the
    // layouts hand the dialog its preferred size, so it hugs its content).
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;

            dialog := Rectangle {
                width: 640px;
                background: Theme.panel-2;
                border-width: 1px;
                border-color: Theme.panel-3;
                border-radius: 12px;

                // Elevation
                drop-shadow-blur: 28px;
                drop-shadow-color: #00000088;
                drop-shadow-offset-y: 10px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 22px;

                    // ── Header ──────────────────────────────
                    VerticalLayout {
                        spacing: 10px;

                        HorizontalLayout {
                            Text {
                                text: "Settings";
                                font-size: 20px;
                                font-weight: 600;
                                color: Theme.txt;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            CloseGlyph {
                                clicked => { root.close(); }
                            }
                        }
                        HorizontalLayout {
                            alignment: start;
                            Rectangle {
                                width: 48px;
                                min-height: 3px;
                                max-height: 3px;
                                border-radius: 2px;
                                background: Theme.gold;
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 20px;

                        // Left nav
                        VerticalLayout {
                            width: 150px;
                            spacing: 4px;
                            NavItem { text: "Appearance"; selected: root.active-tab == 0; clicked => { root.active-tab = 0; } }
                            NavItem { text: "Display";    selected: root.active-tab == 1; clicked => { root.active-tab = 1; } }
                            NavItem { text: "System";     selected: root.active-tab == 2; clicked => { root.active-tab = 2; } }
                            NavItem { text: "Network";    selected: root.active-tab == 3; clicked => { root.active-tab = 3; } }
                            NavItem { text: "About";      selected: root.active-tab == 4; clicked => { root.active-tab = 4; } }
                        }

                        // Right content pane
                        VerticalLayout {
                            horizontal-stretch: 1;
                            if root.active-tab == 0 : Appearance {
                                theme-changed(d) => { root.theme-changed(d); }
                            }
                            if root.active-tab == 1 : Display {
                                resolution-index <=> root.resolution-index;
                                fullscreen <=> root.fullscreen;
                                apply-resolution(i) => { root.apply-resolution(i); }
                                toggle-fullscreen(f) => { root.toggle-fullscreen(f); }
                            }
                            if root.active-tab == 2 : System {
                                os: root.hw-os; device: root.hw-device; ram: root.hw-ram; storage: root.hw-storage;
                            }
                            if root.active-tab == 4 : About { app-version: root.app-version; }
                        }
                    }

                    // ── Footer ──────────────────────────────
                    VerticalLayout {
                        spacing: 16px;

                        Rectangle {
                            min-height: 1px;
                            max-height: 1px;
                            background: Theme.panel-3;
                        }
                        HorizontalLayout {
                            spacing: 8px;

                            TextButton {
                                text: "Reset to defaults";
                                clicked => { root.reset-defaults(); }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Button {
                                text: "Close";
                                clicked => { root.close(); }
                            }
                            GoldButton {
                                text: "Apply";
                                clicked => {
                                    root.apply-resolution(root.resolution-index);
                                    root.close();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
