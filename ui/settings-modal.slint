import { Button, ComboBox, Switch } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { GoldButton } from "widgets/gold-button.slint";

// Eyebrow label that groups a section of settings.
component Eyebrow inherits Text {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: Theme.txt-faint;
}

// Quiet, hover-highlighted text button for secondary actions.
component TextButton inherits Rectangle {
    in property <string> text;
    callback clicked;
    height: 32px;
    border-radius: 6px;
    horizontal-stretch: 0;
    background: touch.has-hover ? Theme.panel-3 : transparent;
    animate background { duration: 120ms; easing: ease-out; }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        Text {
            text: root.text;
            color: touch.has-hover ? Theme.txt : Theme.txt-faint;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Header close affordance (hover-highlighted ✕).
component CloseGlyph inherits Rectangle {
    callback clicked;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: touch.has-hover ? Theme.panel-3 : transparent;
    animate background { duration: 120ms; easing: ease-out; }

    Text {
        text: "✕";
        font-size: 14px;
        color: touch.has-hover ? Theme.txt : Theme.txt-faint;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Full-window modal: scrim + centered, elevated instrument-panel dialog
// that hugs its content. Fades in on open.
export component SettingsModal inherits Rectangle {
    in-out property <int> resolution-index;
    in-out property <bool> fullscreen;
    in property <string> app-version;
    callback apply-resolution(int);
    callback theme-changed(bool);
    callback toggle-fullscreen(bool);
    callback reset-defaults();
    callback close();

    // Drives the fade-in (false -> true on creation).
    property <bool> shown: false;
    init => { shown = true; }

    width: 100%;
    height: 100%;
    background: Theme.overlay;
    opacity: shown ? 1.0 : 0.0;
    animate opacity { duration: 160ms; easing: ease-out; }

    // Center the dialog without stretching it (alignment: center makes the
    // layouts hand the dialog its preferred size, so it hugs its content).
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;

            dialog := Rectangle {
                width: 384px;
                background: Theme.panel-2;
                border-width: 1px;
                border-color: Theme.panel-3;
                border-radius: 12px;

                // Elevation
                drop-shadow-blur: 28px;
                drop-shadow-color: #00000088;
                drop-shadow-offset-y: 10px;

                VerticalLayout {
                    padding: 24px;
                    spacing: 22px;

                    // ── Header ──────────────────────────────
                    VerticalLayout {
                        spacing: 10px;

                        HorizontalLayout {
                            Text {
                                text: "Settings";
                                font-size: 20px;
                                font-weight: 600;
                                color: Theme.txt;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            CloseGlyph {
                                clicked => { root.close(); }
                            }
                        }
                        HorizontalLayout {
                            alignment: start;
                            Rectangle {
                                width: 48px;
                                min-height: 3px;
                                max-height: 3px;
                                border-radius: 2px;
                                background: Theme.gold;
                            }
                        }
                    }

                    // ── Appearance ──────────────────────────
                    VerticalLayout {
                        spacing: 10px;

                        Eyebrow { text: "APPEARANCE"; }
                        HorizontalLayout {
                            Text {
                                text: "Dark mode";
                                color: Theme.txt;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Switch {
                                text: "";
                                checked <=> Theme.dark;
                                toggled => { root.theme-changed(Theme.dark); }
                            }
                        }
                    }

                    // ── Display ─────────────────────────────
                    VerticalLayout {
                        spacing: 12px;

                        Eyebrow { text: "DISPLAY"; }
                        VerticalLayout {
                            spacing: 6px;
                            Text {
                                text: "Resolution";
                                color: Theme.txt-dim;
                            }
                            ComboBox {
                                model: ["800 × 600", "1280 × 720", "1600 × 900", "1920 × 1080"];
                                current-index <=> root.resolution-index;
                            }
                        }
                        HorizontalLayout {
                            Text {
                                text: "Fullscreen";
                                color: Theme.txt;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Switch {
                                text: "";
                                checked <=> root.fullscreen;
                                toggled => { root.toggle-fullscreen(root.fullscreen); }
                            }
                        }
                    }

                    // ── About ───────────────────────────────
                    VerticalLayout {
                        spacing: 6px;

                        Eyebrow { text: "ABOUT"; }
                        HorizontalLayout {
                            Text {
                                text: "Denso Digital Reader";
                                color: Theme.txt-dim;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: "v\{root.app-version}";
                                color: Theme.txt-faint;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // ── Footer ──────────────────────────────
                    VerticalLayout {
                        spacing: 16px;

                        Rectangle {
                            min-height: 1px;
                            max-height: 1px;
                            background: Theme.panel-3;
                        }
                        HorizontalLayout {
                            spacing: 8px;

                            TextButton {
                                text: "Reset to defaults";
                                clicked => { root.reset-defaults(); }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Button {
                                text: "Close";
                                clicked => { root.close(); }
                            }
                            GoldButton {
                                text: "Apply";
                                clicked => {
                                    root.apply-resolution(root.resolution-index);
                                    root.close();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
