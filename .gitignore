# CMake out-of-source build dirs
/build
/build-*
/out
/cmake-build-*

# Runtime SQLite store (created next to the executable)
denso.db
denso.db-shm
denso.db-wal

# Screenshots / generated images (assets/icon.png is force-tracked)
*.png

# ONNX Runtime binaries (provisioned per platform, not tracked)
third_party/onnxruntime/

# CUDA execution-provider runtime DLLs (TensorRT + cuDNN), provisioned locally
# and copied beside the exe at build time — see docs/GPU_SETUP.md. Not tracked.
third_party/gpu_ep/

# TensorRT engines + the ORT TensorRT-EP engine cache — built locally and
# specific to the GPU architecture and TensorRT version, so never tracked.
models/*.engine
models/trt_cache/
