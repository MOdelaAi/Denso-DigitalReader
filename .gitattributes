# Normalize line endings: store text as LF in the repo, check out native.
* text=auto eol=lf

# Explicit text types
*.h              text eol=lf
*.cpp            text eol=lf
*.cmake          text eol=lf
CMakeLists.txt   text eol=lf
*.md             text eol=lf
*.txt            text eol=lf
*.json           text eol=lf

# Binary assets — never normalize
*.png     binary
*.ico     binary
*.jpg     binary
