# Normalize line endings: store text as LF in the repo, check out native.
* text=auto eol=lf

# Explicit text types
*.rs      text eol=lf
*.slint   text eol=lf
*.toml    text eol=lf
*.md      text eol=lf
*.json    text eol=lf

# Binary assets — never normalize
*.png     binary
*.ico     binary
*.jpg     binary
